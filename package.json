{
  "name": "nearby-api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint . --fix",
    "test": "jest --config jest.config.json",
    "test:watch": "jest --config jest.config.json --watch",
    "test:cov": "jest --config jest.config.json --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --config jest.config.json --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand --forceExit",
    "test:int": "jest --config ./test/jest-int.json",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:generate": "npm run typeorm -- migration:generate -d src/infra/database/data-source.config.ts src/infra/database/migrations/$npm_config_name",
    "migration:run": "npm run typeorm -- migration:run -d src/infra/database/data-source.config.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d src/infra/database/data-source.config.ts",
    "seed": "ts-node -r tsconfig-paths/register src/infra/database/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.1016.0",
    "@aws-sdk/client-s3": "^3.1014.0",
