{
 "moduleFileExtensions": [
  "js",
  "json",
  "ts"
 ],
 "rootDir": "src",
 "testRegex": ".*\\.spec\\.ts$",
 "transform": {
  "^.+\\.(t|j)s$": "ts-jest"
 },
 "transformIgnorePatterns": [
  "/node_modules/(?!(@paralleldrive/cuid2|uuid|@noble)/)"
 ],
 "collectCoverageFrom": [
  "**/*.(t|j)s",
  "!**/*.module.ts",
  "!**/*.config.ts",
  "!**/*.dto.ts",
  "!**/*.entity.ts",
  "!**/*.enum.ts",
  "!**/*.decorator.ts",
  "!**/*.config.ts",
  "!**/*.mock.ts",
  "!**/main.ts",
  "!**/infra/database/migration/**"
 ],
 "coverageDirectory": "../coverage",
 "testEnvironment": "node",
 "moduleNameMapper": {
  "^@services/(.*)$": "<rootDir>/services/$1",
  "^@infra/(.*)$": "<rootDir>/infra/$1",
  "^@config/(.*)$": "<rootDir>/config/$1",
  "^@common/(.*)$": "<rootDir>/common/$1",
  "^@auth/(.*)$": "<rootDir>/modules/auth/$1",
  "^@events/(.*)$": "<rootDir>/modules/events/$1",
  "^@orders/(.*)$": "<rootDir>/modules/orders/$1",
  "^@ticket-types/(.*)$": "<rootDir>/modules/ticket-types/$1",
  "^@tickets/(.*)$": "<rootDir>/modules/tickets/$1",
  "^@users/(.*)$": "<rootDir>/modules/users/$1"
 }
}